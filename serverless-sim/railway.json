{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install torch --index-url https://download.pytorch.org/whl/cpu && pip install -r requirements-web.txt"
  },
  "deploy": {
    "startCommand": "python web_start.py",
    "healthcheckPath": "/api/v1/central/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
