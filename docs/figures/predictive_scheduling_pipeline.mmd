flowchart LR
  %% Paper-ready offline training + online inference pipeline for predictive scheduling

  subgraph OFF["Offline Model Pipeline (predict-model-with-taxi)"]
    RAW["Raw trajectories\n(T-Drive taxi logs)"]
    MAP["Road network\n(OSM XML/GraphML)"]
    PREP["Data preparation\nPhase A / Phase B\n(map-matching, features, splits)"]
    TRAIN["Model training\nGRU baseline"]
    EVAL["Evaluation\n(GRU + baselines)"]
    ART["Artifacts\n(checkpoint + metadata)"]
  end

  subgraph ONLINE["Online Use (serverless-sim Central Node)"]
    HIST["Per-user history buffer\n(last N points, meters + features)"]
    INF["TDrivePredictorAdapter\n(load bundle + batch inference)"]
    PROB["Cloudlet probability scores\nper user"]
    ASSIGN["Predictive assignment\n(resource constraints + handoff cost)"]
  end

  RAW --> PREP
  MAP --> PREP
  PREP --> TRAIN --> ART
  PREP --> EVAL
  TRAIN --> EVAL

  %% Runtime dependency
  ART -. "loaded at startup\n(Config.TDRIVE_ARTIFACT_DIR)" .-> INF
  HIST --> INF --> PROB --> ASSIGN

